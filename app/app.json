{
  "expo": {
    "name": "Fraktl",
    "slug": "fraktl",
    "version": "1.0.0",
    "scheme": "fraktl",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#010808"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fraktl.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#010808"
      },
      "package": "com.fraktl.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Fraktl necesita acceso a la cámara para escanear árboles."
        }
      ]
    ]
  }
}
